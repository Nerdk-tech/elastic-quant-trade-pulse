import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { base44 } from '@/api/base44Client';
import { Card } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Textarea } from '@/components/ui/textarea';
import { toast } from 'sonner';
import { ArrowUpRight, Shield, Wallet, Zap, ChevronRight, CheckCircle2 } from 'lucide-react';
import { haptic } from '@/lib/haptics';
import { motion, AnimatePresence } from 'framer-motion';
import { useQuery } from '@tanstack/react-query';

const COINS = [
  { value: 'USDT_TRC20', label: 'USDT (TRC-20)', network: 'Tron Network', color: 'text-red-400', icon: '🔴' },
  { value: 'USDT_ERC20', label: 'USDT (ERC-20)', network: 'Ethereum Network', color: 'text-blue-400', icon: '🔵' },
  { value: 'BTC', label: 'Bitcoin (BTC)', network: 'Bitcoin Network', color: 'text-orange-400', icon: '🟠' },
];

const WALLETS = [
  { id: 'metamask', name: 'MetaMask', icon: '🦊' },
  { id: 'trustwallet', name: 'Trust Wallet', icon: '🛡️' },
  { id: 'coinbase', name: 'Coinbase Wallet', icon: '🔵' },
  { id: 'phantom', name: 'Phantom', icon: '👻' },
  { id: 'walletconnect', name: 'WalletConnect', icon: '🔗' },
  { id: 'ledger', name: 'Ledger', icon: '🔒' },
];

export default function Withdraw() {
  const navigate = useNavigate();
  const [step, setStep] = useState(1); // 1=form, 2=wallet-connect, 3=success
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(false);
  const [form, setForm] = useState({ amount: '', coin: '', address: '' });

  const [selectedWallet, setSelectedWallet] = useState('');
  const [withdrawalId, setWithdrawalId] = useState(null);

  useEffect(() => { base44.auth.me().then(setUser); }, []);

  const { data: wallets = [] } = useQuery({
    queryKey: ['user-wallet', user?.id],
    queryFn: () => base44.entities.Wallet.filter({ user_id: user?.id }),
    enabled: !!user,
  });

  const userWallet = wallets[0];
  const balance = userWallet?.balance || 0;

  const submitForm = async () => {
    if (!form.amount || parseFloat(form.amount) <= 0) { haptic.error(); return toast.error('Enter a valid amount'); }
    if (parseFloat(form.amount) > balance) { haptic.error(); return toast.error('Insufficient balance'); }
    if (!form.coin) { haptic.error(); return toast.error('Select a coin/network'); }
    if (!form.address.trim()) { haptic.error(); return toast.error('Enter a wallet address'); }
    haptic.medium();
    setStep(2);
  };

  const saveWithdrawalAndContinue = async (method, extra = {}) => {
    setLoading(true);
    const record = await base44.entities.Withdrawal.create({
      user_id: user.id,
      amount: parseFloat(form.amount),
      coin: form.coin,
      wallet_address: form.address,
      connection_method: method,
      status: 'pending',
      ...extra,
    });
    setWithdrawalId(record.id);
    await base44.entities.Transaction.create({
      user_id: user.id,
      type: 'withdrawal',
      amount: parseFloat(form.amount),
      currency: 'USD',
      status: 'pending',
      description: `Withdrawal via ${form.coin} — pending review`,
      asset: form.coin,
    });
    setLoading(false);
    setStep(4);
  };

  const connectAutoWallet = async (walletName) => {
    setSelectedWallet(walletName);
    await saveWithdrawalAndContinue('automatic', { wallet_type: walletName });
  };

  const selectedCoin = COINS.find(c => c.value === form.coin);

  return (
    <div className="max-w-lg mx-auto space-y-6 pb-20">
      {/* Header */}
      <div className="flex items-center gap-3">
        <div className="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
          <ArrowUpRight className="w-5 h-5 text-primary" />
        </div>
        <div>
          <h1 className="font-display text-2xl font-bold">Withdraw Funds</h1>
          <p className="text-sm text-muted-foreground">Available: <span className="font-semibold text-foreground">${balance.toLocaleString('en-US', { minimumFractionDigits: 2 })}</span></p>
        </div>
      </div>

      {/* Step indicator */}
      <div className="flex items-center gap-2">
        {[1, 2].map(s => (
          <React.Fragment key={s}>
            <div className={`w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-colors ${step >= s ? 'bg-primary text-primary-foreground border-primary' : 'border-border text-muted-foreground'}`}>{s}</div>
            {s < 2 && <div className={`flex-1 h-0.5 transition-colors ${step > s ? 'bg-primary' : 'bg-border'}`} />}
          </React.Fragment>
        ))}
        <div className="ml-2 text-xs text-muted-foreground">
          {step === 1 && 'Details'}{step === 2 && 'Connect Wallet'}{step === 3 && 'Done'}
        </div>
      </div>

      <AnimatePresence mode="wait">

        {/* STEP 1 — Form */}
        {step === 1 && (
          <motion.div key="step1" initial={{ opacity: 0, x: 30 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -30 }}>
            <Card className="p-6 space-y-5 bg-card border-border/50">
              <div>
                <Label className="text-xs text-muted-foreground font-mono">Amount (USD)</Label>
                <Input type="number" placeholder="0.00" value={form.amount} onChange={e => setForm(f => ({ ...f, amount: e.target.value }))} className="bg-secondary/50 font-mono mt-1 text-lg" />
                <p className="text-xs text-muted-foreground mt-1">Min: $50 · Balance: ${balance.toLocaleString()}</p>
              </div>

              <div>
                <Label className="text-xs text-muted-foreground font-mono">Coin / Network</Label>
                <Select value={form.coin} onValueChange={v => setForm(f => ({ ...f, coin: v }))}>
                  <SelectTrigger className="bg-secondary/50 mt-1">
                    <SelectValue placeholder="Select coin and network..." />
                  </SelectTrigger>
                  <SelectContent>
                    {COINS.map(c => (
                      <SelectItem key={c.value} value={c.value}>
                        <span className="flex items-center gap-2">
                          <span>{c.icon}</span>
                          <span className="font-semibold">{c.label}</span>
                          <span className="text-xs text-muted-foreground">· {c.network}</span>
                        </span>
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
                {selectedCoin && (
                  <p className={`text-xs mt-1 ${selectedCoin.color}`}>Network: {selectedCoin.network}</p>
                )}
              </div>

              <div>
                <Label className="text-xs text-muted-foreground font-mono">Receiving Wallet Address</Label>
                <Input placeholder={form.coin === 'BTC' ? 'bc1q...' : '0x...'} value={form.address} onChange={e => setForm(f => ({ ...f, address: e.target.value }))} className="bg-secondary/50 font-mono mt-1" />
                <p className="text-xs text-muted-foreground mt-1">Enter the correct address for the selected network</p>
              </div>

              <Button onClick={submitForm} className="w-full h-11 font-semibold">
                Continue <ChevronRight className="w-4 h-4 ml-1" />
              </Button>
            </Card>
          </motion.div>
        )}

        {/* STEP 2 — Wallet Connect Choice */}
        {step === 2 && (
          <motion.div key="step2" initial={{ opacity: 0, x: 30 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -30 }} className="space-y-4">
            <Card className="p-5 bg-card border-border/50">
              <div className="text-center mb-6">
                <div className="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-3">
                  <Wallet className="w-7 h-7 text-primary" />
                </div>
                <h2 className="font-display text-xl font-bold">Connect Wallet</h2>
                <p className="text-sm text-muted-foreground mt-1">Connect your wallet to complete the withdrawal of <span className="font-semibold text-foreground">${parseFloat(form.amount || 0).toLocaleString()}</span></p>
              </div>

              <button onClick={() => setStep('auto')}
                className="flex items-center gap-4 p-4 rounded-xl border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left group">
                <div className="w-11 h-11 rounded-xl bg-blue-500/10 flex items-center justify-center flex-shrink-0">
                  <Zap className="w-5 h-5 text-blue-400" />
                </div>
                <div className="flex-1">
                  <p className="font-semibold text-sm">Connect Your Wallet</p>
                  <p className="text-xs text-muted-foreground">Connect via MetaMask, Trust Wallet, or other wallets</p>
                </div>
                <ChevronRight className="w-4 h-4 text-muted-foreground group-hover:text-primary transition-colors" />
              </button>

              <button onClick={() => setStep(1)} className="w-full mt-4 text-xs text-muted-foreground hover:text-foreground transition-colors">← Go back</button>
            </Card>
          </motion.div>
        )}

        {/* STEP 2b — Automatic wallet list */}
        {step === 'auto' && (
          <motion.div key="auto" initial={{ opacity: 0, x: 30 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -30 }} className="space-y-4">
            <Card className="p-5 bg-card border-border/50">
              <div className="flex items-center gap-3 mb-5">
                <Zap className="w-5 h-5 text-blue-400" />
                <h2 className="font-display text-lg font-bold">Select Your Wallet</h2>
              </div>
              <div className="grid grid-cols-2 gap-3">
                {WALLETS.map(w => (
                  <button key={w.id} onClick={() => connectAutoWallet(w.name)} disabled={loading}
                    className="flex flex-col items-center gap-2 p-4 rounded-xl border border-border hover:border-primary/50 hover:bg-primary/5 transition-all">
                    <span className="text-2xl">{w.icon}</span>
                    <span className="text-sm font-semibold">{w.name}</span>
                  </button>
                ))}
              </div>
              <button onClick={() => setStep(2)} className="w-full mt-4 text-xs text-muted-foreground hover:text-foreground transition-colors">← Go back</button>
            </Card>
          </motion.div>
        )}

        {/* STEP 3 — Success */}
        {step === 3 && (
          <motion.div key="step3" initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }}>
            <Card className="p-6 space-y-5 bg-card border-border/50">
              <div className="flex flex-col items-center text-center gap-3 py-2">
                <div className="w-14 h-14 rounded-full bg-green-100 flex items-center justify-center">
                  <CheckCircle2 className="w-7 h-7 text-green-600" />
                </div>
                <h2 className="font-display text-lg font-bold text-foreground">Withdrawal Processing</h2>
              </div>

              <div className="p-4 rounded-xl bg-green-50 border border-green-200">
                <p className="text-sm text-green-800 leading-relaxed text-center">
                  Your withdrawal request has been submitted successfully. We're processing your {form.coin} transfer to your wallet address.
                </p>
              </div>

              <div className="space-y-2 text-sm">
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Amount:</span>
                  <span className="font-semibold">${parseFloat(form.amount || 0).toLocaleString()}</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Network:</span>
                  <span className="font-semibold">{selectedCoin?.network}</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-muted-foreground">Status:</span>
                  <span className="font-semibold text-amber-600">Pending</span>
                </div>
              </div>

              <Button variant="outline" onClick={() => navigate('/dashboard')} className="w-full h-10">
                Back to Dashboard
              </Button>
            </Card>
          </motion.div>
        )}

      </AnimatePresence>
    </div>
  );
}