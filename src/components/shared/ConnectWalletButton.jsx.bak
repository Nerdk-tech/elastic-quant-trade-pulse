import React, { useState } from 'react';
import { Button } from '@/components/ui/button';
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle } from '@/components/ui/dialog';
import { Wallet, Check, Copy, X, ChevronRight } from 'lucide-react';

export default function ConnectWalletButton({ size = 'default', className = '' }) {
  const [connected, setConnected] = useState(false);
  const [address, setAddress] = useState('');
  const [copied, setCopied] = useState(false);
  const [modalOpen, setModalOpen] = useState(false);

  const mockAddresses = [
    '0xA3F8...91C2', '0x7B2E...44D1', '0xC9A1...F83B', '0x5D7E...22A9'
  ];

  const wallets = [
    { name: 'MetaMask', icon: '🦊', color: 'bg-orange-50 hover:bg-orange-100 border-orange-200' },
    { name: 'Trust Wallet', icon: '💙', color: 'bg-blue-50 hover:bg-blue-100 border-blue-200' },
    { name: 'Coinbase Wallet', icon: '⚫', color: 'bg-gray-50 hover:bg-gray-100 border-gray-200' },
    { name: 'WalletConnect', icon: '🔵', color: 'bg-indigo-50 hover:bg-indigo-100 border-indigo-200' },
  ];

  const handleConnect = (walletName) => {
    const addr = mockAddresses[Math.floor(Math.random() * mockAddresses.length)];
    setAddress(addr);
    setConnected(true);
    setModalOpen(false);
  };

  const copyAddress = (e) => {
    e.stopPropagation();
    navigator.clipboard.writeText(address);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const disconnect = (e) => {
    e.stopPropagation();
    setConnected(false);
    setAddress('');
  };

  if (connected) {
    return (
      <button
        onClick={copyAddress}
        className={`inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 hover:bg-primary/15 transition-colors ${className}`}
      >
        <div className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse" />
        <span className="text-xs font-semibold text-primary">{address}</span>
        {copied ? <Check className="w-3 h-3 text-emerald-500" /> : <Copy className="w-3 h-3 text-primary/60" />}
      </button>
    );
  }

  return (
    <>
      <Button
        size={size}
        variant="outline"
        onClick={() => setModalOpen(true)}
        className={`border-primary/30 text-primary hover:bg-primary/10 gap-2 rounded-full ${className}`}
      >
        <Wallet className="w-3.5 h-3.5" />
        Connect Wallet
      </Button>

      <Dialog open={modalOpen} onOpenChange={setModalOpen}>
        <DialogContent className="sm:max-w-md">
          <DialogHeader>
            <DialogTitle className="text-lg">Connect Wallet</DialogTitle>
            <DialogDescription>
              Select a wallet to connect to your account
            </DialogDescription>
          </DialogHeader>

          <div className="space-y-3">
            {wallets.map((wallet) => (
              <button
                key={wallet.name}
                onClick={() => handleConnect(wallet.name)}
                className={`w-full flex items-center gap-3 p-4 rounded-xl border-2 transition-all ${wallet.color}`}
              >
                <span className="text-2xl">{wallet.icon}</span>
                <span className="flex-1 text-left font-semibold text-gray-900">{wallet.name}</span>
                <ChevronRight className="w-4 h-4 text-gray-500" />
              </button>
            ))}
          </div>

          <button
            onClick={() => setModalOpen(false)}
            className="w-full mt-4 p-2 text-sm text-gray-500 hover:text-gray-900 transition-colors"
          >
            Cancel
          </button>
        </DialogContent>
      </Dialog>
    </>
  );
}