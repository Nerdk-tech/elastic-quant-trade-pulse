{
  "name": "User",
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "user"
      ],
      "default": "user"
    },
    "security_code": {
      "type": "string",
      "description": "Unique security code for admin access delegation"
    }
  }
}